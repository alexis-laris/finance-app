generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String  @id @default(cuid())
  name      String
  email     String  @unique
  password  String
  role      Role    @default(USER)
  avatarUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses    Expense[]
  incomes     Income[]
  categories  Category[]
  payments    Payment[]
  savingGoals SavingGoal[]
}

model Expense {
  id          String  @id @default(uuid())
  amount      Float
  description String?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  date      DateTime @default(now())

  @@index([userId])
}

model Income {
  id     String @id @default(uuid())
  amount Float

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  date        DateTime @default(now())
  description String?

  @@index([userId])
}

model Payment {
  id String @id @default(uuid())

  name        String
  amount      Float
  description String?

  type   PaymentType
  status PaymentStatus @default(PENDING)

  scheduledAt DateTime
  paidAt      DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([scheduledAt])
}

model Category {
  id          String  @id @default(uuid())
  name        String
  icon        String
  color       String?
  description String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expenses Expense[]
  payments Payment[]

  createdAt DateTime @default(now())

  @@unique([name, userId])
  @@index([userId])
}

model SavingGoal {
  id String @id @default(uuid())

  name          String
  targetAmount  Float
  currentAmount Float  @default(0)

  deadline DateTime
  note     String?

  status SavingGoalStatus @default(ACTIVE)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contributions SavingGoalContribution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([deadline])
  @@index([status])
  @@index([userId, status])
}

model SavingGoalContribution {
  id String @id @default(uuid())

  amount Float
  note   String?

  savingGoalId String
  savingGoal   SavingGoal @relation(fields: [savingGoalId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([savingGoalId])
}

enum Role {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
}

enum PaymentType {
  INCOME
  EXPENSE
}

enum SavingGoalStatus {
  ACTIVE
  COMPLETED
  FAILED
}
